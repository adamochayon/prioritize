{
  "extends": ["html-validate:recommended"],
  "rules": {
    "no-inline-style": "off",
    "script-type": "off",
    "long-title": "off",
    "attribute-boolean-style": "off",
    "void-style": "off",
    "doctype-style": "off",
    "element-required-attributes": "off",
    "no-implicit-button-type": "off"
  }
}
